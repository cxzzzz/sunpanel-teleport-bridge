SUNPANEL_BASE_URL=http://192.168.100.106:3002
SUNPANEL_USERNAME=replace-me
SUNPANEL_PASSWORD=replace-me
SUNPANEL_INSECURE_SKIP_VERIFY=false

# url, lanUrl, preferLanUrl, preferUrl
SUNPANEL_URL_FIELD=preferLanUrl

# Defaults match SunPanel 1.8.1 panel APIs. Override only if your deployment changes routes.
SUNPANEL_LOGIN_ENDPOINT=/api/login
SUNPANEL_ITEMS_ENDPOINT=/api/panel/itemIcon/getListAllGroup

TELEPORT_MANAGED_BY=sunpanel-teleport-bridge
TELEPORT_PROXY=192.168.100.106:3080
TELEPORT_JOIN_TOKEN=replace-me
TELEPORT_INSECURE_SKIP_VERIFY=false
TELEPORT_APP_INSECURE_SKIP_VERIFY=true
TELEPORT_APP_USE_ANY_PROXY_PUBLIC_ADDR=true
TELEPORT_DATA_VOLUME=/opt/sunpanel-teleport-bridge/data
TELEPORT_CONFIG_VOLUME=/opt/sunpanel-teleport-bridge/config
TELEPORT_DATA_DIR=/var/lib/teleport
TELEPORT_CONFIG_PATH=/etc/teleport/sunpanel-apps.yaml
BRIDGE_CONFIG_VOLUME=/opt/sunpanel-teleport-bridge/bridge-config
APP_OVERRIDES_PATH=/etc/sunpanel-teleport-bridge/overrides.yaml
SYNC_INTERVAL=300s
DRY_RUN=true
LOG_LEVEL=info
